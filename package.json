{
  "name": "techfinances-v2",
  "version": "2.0.0",
  "private": true,
  "description": "Aplicacao full-stack de financas pessoais com dashboard, API, autenticacao, PostgreSQL e exportacao Excel.",
  "scripts": {
    "dev": "npm --prefix backend run dev",
    "start": "npm --prefix backend start",
    "install:all": "npm install --prefix backend",
    "db:start": "powershell -ExecutionPolicy Bypass -File database/start-local-postgres.ps1",
    "db:stop": "powershell -ExecutionPolicy Bypass -File database/stop-local-postgres.ps1",
    "db:push": "powershell -ExecutionPolicy Bypass -File database/push-prisma.ps1",
    "test": "powershell -ExecutionPolicy Bypass -File database/test-backend.ps1",
    "db:seed": "npm --prefix backend run db:seed",
    "prisma:generate": "npm --prefix backend run prisma:generate",
    "prisma:migrate": "npm --prefix backend run prisma:migrate"
  }
}
