generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransactionType {
  income
  expense
}

model User {
  id             String           @id @default(uuid())
  name           String
  email          String           @unique
  passwordHash   String           @map("password_hash")
  emailVerifiedAt DateTime?       @map("email_verified_at")
  emailVerificationTokenHash String? @map("email_verification_token_hash")
  emailVerificationExpiresAt DateTime? @map("email_verification_expires_at")
  passwordResetTokenHash String?  @map("password_reset_token_hash")
  passwordResetExpiresAt DateTime? @map("password_reset_expires_at")
  twoFactorEnabled Boolean        @default(false) @map("two_factor_enabled")
  twoFactorSecret  String?        @map("two_factor_secret")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  transactions   Transaction[]
  budgetSettings BudgetSettings?
  emergencyGoal  EmergencyGoal?
  trustedDevices TrustedDevice[]
  categories      Category[]

  @@map("users")
}

model Category {
  id        String          @id @default(uuid())
  name      String
  type      TransactionType
  group     String          @default("variavel")
  userId    String          @map("user_id")
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, name])
  @@index([userId, type])
  @@map("categories")
}

model TrustedDevice {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  deviceHash String   @map("device_hash")
  trustedAt  DateTime @default(now()) @map("trusted_at")
  lastUsedAt DateTime @default(now()) @map("last_used_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceHash])
  @@index([userId])
  @@map("trusted_devices")
}

model Transaction {
  id          String          @id @default(uuid())
  type        TransactionType
  date        DateTime
  category    String
  description String
  amount      Decimal         @db.Decimal(12, 2)
  userId      String          @map("user_id")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@map("transactions")
}

model BudgetSettings {
  id        String   @id @default(uuid())
  salary    Decimal  @default(2500) @db.Decimal(12, 2)
  needsPct  Int      @default(50) @map("needs_pct")
  wantsPct  Int      @default(30) @map("wants_pct")
  futurePct Int      @default(20) @map("future_pct")
  userId    String   @unique @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("budget_settings")
}

model EmergencyGoal {
  id        String   @id @default(uuid())
  months    Int      @default(6)
  current   Decimal  @default(300) @db.Decimal(12, 2)
  userId    String   @unique @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("emergency_goals")
}
